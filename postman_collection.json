              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dosage\": \"1000\",\n  \"instructions\": \"Take with plenty of water\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/medicines/:medicine_id",
              "host": ["{{base_url}}"],
              "path": ["medicines", ":medicine_id"],
              "variable": [
                {
                  "key": "medicine_id",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Delete Medicine",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/medicines/:medicine_id",
              "host": ["{{base_url}}"],
              "path": ["medicines", ":medicine_id"],
              "variable": [
                {
                  "key": "medicine_id",
                  "value": ""
                }
              ]
            }
          }
        }
