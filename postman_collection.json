              "raw": "{{base_url}}/medicines",
              "host": ["{{base_url}}"],
              "path": ["medicines"]
            }
          }
        },
        {
          "name": "Get Medicine by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/medicines/:medicine_id",
              "host": ["{{base_url}}"],
              "path": ["medicines", ":medicine_id"],
              "variable": [
                {
                  "key": "medicine_id",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Update Medicine",
          "request": {
            "method": "PUT",
