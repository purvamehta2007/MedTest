              "raw": "{{base_url}}/intakes/adherence?days=30",
              "host": ["{{base_url}}"],
              "path": ["intakes", "adherence"],
              "query": [
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            }
          }
