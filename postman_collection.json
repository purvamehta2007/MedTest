                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aspirin\",\n  \"description\": \"Pain reliever\",\n  \"dosage\": \"500\",\n  \"unit\": \"mg\",\n  \"frequency\": \"as needed\",\n  \"form\": \"tablet\",\n  \"manufacturer\": \"Generic Pharma\",\n  \"instructions\": \"Take with food\",\n  \"side_effects\": \"Stomach upset\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/medicines",
              "host": ["{{base_url}}"],
              "path": ["medicines"]
